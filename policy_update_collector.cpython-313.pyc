from src.rule_engine import load_latest_policy_rules


def collect_reimbursement_revision_signals(hospital_name: str):
    rules = load_latest_policy_rules()
    return [
        {
            "hospital_name": hospital_name,
            "revision_signal": item.get("title", "制度更新情報あり"),
            "note": item.get("summary", "最新ルールを判定へ反映"),
            "source_url": item.get("source_url"),
        }
        for item in rules
    ]
