import json
import os
from datetime import datetime
from src.settings import KNOWLEDGE_DIR
from src.collectors.policy_update_collector import collect_policy_updates


def refresh_policy_knowledge() -> dict:
    os.makedirs(KNOWLEDGE_DIR, exist_ok=True)
    items = collect_policy_updates()
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(KNOWLEDGE_DIR, f"policy_updates_{timestamp}.json")
    with open(path, "w", encoding="utf-8") as f:
        json.dump(items, f, ensure_ascii=False, indent=2)
    return {"updated_count": len(items), "items": items, "path": path}
