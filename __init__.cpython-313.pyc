from __future__ import annotations

import re
from bs4 import BeautifulSoup
from src.models import HospitalProfile
from src.search_utils import search_web, fetch_page

PHONE_RE = re.compile(r"0\d{1,4}-\d{1,4}-\d{3,4}")
BED_RE = re.compile(r"(病床数|許可病床)\s*[:：]?\s*(\d{1,4})")


def collect_hospital_profile(hospital_name: str, prefecture: str = ""):
    query = f'{prefecture} {hospital_name} 公式 病院' if prefecture else f'{hospital_name} 公式 病院'
    results = search_web(query, max_results=5)
    website_url = None
    source_url = None
    for result in results:
        if hospital_name[:2] in result["title"] or hospital_name[:2] in result["snippet"]:
            website_url = result["url"]
            source_url = result["url"]
            break
    address = None
    phone = None
    bed_count = None
    departments = None
    corporation_name = None
    if website_url:
        html = fetch_page(website_url)
        soup = BeautifulSoup(html, "lxml") if html else None
        text = soup.get_text(" ", strip=True) if soup else ""
        phone_match = PHONE_RE.search(text)
        if phone_match:
            phone = phone_match.group(0)
        bed_match = BED_RE.search(text)
        if bed_match:
            bed_count = bed_match.group(2)
        title = soup.title.get_text(" ", strip=True) if soup and soup.title else None
        if title:
            corporation_name = title[:120]
        m = re.search(r"(住所|所在地)\s*[:：]?\s*([^\n]+)", text)
        if m:
            address = m.group(2)[:150]
        dep = re.search(r"(診療科|標榜科)\s*[:：]?\s*([^\n]+)", text)
        if dep:
            departments = dep.group(2)[:200]
    return [
        HospitalProfile(
            hospital_name=hospital_name,
            corporation_name=corporation_name,
            prefecture=prefecture or None,
            address=address,
            phone=phone,
            website_url=website_url,
            bed_count=bed_count,
            departments=departments,
            source_url=source_url,
        ).model_dump()
    ]
