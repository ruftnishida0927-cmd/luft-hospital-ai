from typing import List, Optional
from pydantic import BaseModel, Field


class HospitalProfile(BaseModel):
    hospital_name: str
    corporation_name: Optional[str] = None
    prefecture: Optional[str] = None
    address: Optional[str] = None
    phone: Optional[str] = None
    website_url: Optional[str] = None
    bed_count: Optional[str] = None
    departments: Optional[str] = None
    owner_type: Optional[str] = None
    source_url: Optional[str] = None


class HiringContactCandidate(BaseModel):
    hospital_name: str
    person_name: Optional[str] = None
    title: Optional[str] = None
    contact_type: Optional[str] = None
    contact_value: Optional[str] = None
    source_url: Optional[str] = None
    evidence_text: Optional[str] = None
    confidence_score: float = 0.0


class FacilityStandardSignal(BaseModel):
    hospital_name: str
    category: Optional[str] = None
    standard_name: str
    source_name: Optional[str] = None
    source_url: Optional[str] = None
    evidence_text: Optional[str] = None
    confidence_score: float = 0.0


class RecruitmentSignal(BaseModel):
    hospital_name: str
    job_type: Optional[str] = None
    employment_type: Optional[str] = None
    channel_name: Optional[str] = None
    job_url: Optional[str] = None
    comment: Optional[str] = None


class PhaseSignal(BaseModel):
    hospital_name: str
    signal_type: str
    signal_detail: str
    predicted_phase: str
    expected_issue: str
    sales_angle: str
    recommended_roles: str
    priority_score: int = 50


class HospitalAnalysisResult(BaseModel):
    summary_markdown: str
    hospital_profile: List[dict] = Field(default_factory=list)
    hiring_contacts: List[dict] = Field(default_factory=list)
    facility_standards: List[dict] = Field(default_factory=list)
    recruitment_signals: List[dict] = Field(default_factory=list)
    phase_signals: List[dict] = Field(default_factory=list)
    policy_updates: List[dict] = Field(default_factory=list)
    summary_table: List[dict] = Field(default_factory=list)
