from __future__ import annotations

import re
from src.models import HiringContactCandidate
from src.search_utils import search_web, fetch_page

NAME_RE = re.compile(r"([一-龥ぁ-んァ-ヶ]{2,8}\s?[一-龥ぁ-んァ-ヶ]{1,8})")
EMAIL_RE = re.compile(r"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}")
PHONE_RE = re.compile(r"0\d{1,4}-\d{1,4}-\d{3,4}")


def collect_hiring_contacts(hospital_name: str):
    queries = [
        f'{hospital_name} 看護部長',
        f'{hospital_name} 採用 人事',
        f'{hospital_name} 事務長',
        f'{hospital_name} 総務 採用',
    ]
    candidates = []
    seen = set()
    for query in queries:
        for result in search_web(query, max_results=2):
            html = fetch_page(result["url"])
            text = re.sub(r"\s+", " ", html)
            title = None
            contact_type = "採用窓口候補"
            for token in ["看護部長", "事務長", "人事", "総務", "採用"]:
                if token in result["title"] or token in result["snippet"] or token in text:
                    title = token
                    break
            email = EMAIL_RE.search(text)
            phone = PHONE_RE.search(text)
            person_name = None
            if title:
                near = re.search(rf"({title}.{{0,20}})", text)
                if near:
                    m = NAME_RE.search(near.group(1))
                    if m:
                        person_name = m.group(1)
            key = (person_name, title, result["url"])
            if key in seen:
                continue
            seen.add(key)
            candidates.append(
                HiringContactCandidate(
                    hospital_name=hospital_name,
                    person_name=person_name,
                    title=title or "採用関連役職候補",
                    contact_type=contact_type,
                    contact_value=(email.group(0) if email else phone.group(0) if phone else None),
                    source_url=result["url"],
                    evidence_text=(result["snippet"] or result["title"])[:200],
                    confidence_score=0.4 if person_name else 0.25,
                ).model_dump()
            )
    if not candidates:
        candidates.append(
            HiringContactCandidate(
                hospital_name=hospital_name,
                title="人事 / 総務 / 看護部長 / 事務長 候補を要確認",
                contact_type="採用窓口候補",
                evidence_text="公開情報から明確な候補を取得できませんでした。代表窓口確認を推奨。",
                confidence_score=0.1,
            ).model_dump()
        )
    return candidates
