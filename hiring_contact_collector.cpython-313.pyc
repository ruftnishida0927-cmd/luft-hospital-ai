from __future__ import annotations

from src.models import FacilityStandardSignal
from src.search_utils import search_web

KEYWORDS = [
    ("急性期", ["急性期一般入院料", "救急医療", "HCU", "ICU"]),
    ("回復期", ["回復期リハビリテーション病棟入院料", "地域包括ケア病棟入院料"]),
    ("慢性期", ["療養病棟入院基本料", "障害者施設等入院基本料"]),
    ("在宅", ["在宅療養支援病院", "訪問診療", "在宅"]),
]


def collect_facility_standards(hospital_name: str):
    results = []
    seen = set()
    for category, terms in KEYWORDS:
        for term in terms:
            for item in search_web(f'{hospital_name} {term}', max_results=1):
                key = (category, term, item['url'])
                if key in seen:
                    continue
                seen.add(key)
                results.append(
                    FacilityStandardSignal(
                        hospital_name=hospital_name,
                        category=category,
                        standard_name=term,
                        source_name="web_search",
                        source_url=item["url"],
                        evidence_text=item["snippet"],
                        confidence_score=0.35,
                    ).model_dump()
                )
    if not results:
        results.append(
            FacilityStandardSignal(
                hospital_name=hospital_name,
                category="要調査",
                standard_name="施設基準の明示的な公開情報を検出できませんでした",
                source_name="system",
                confidence_score=0.1,
            ).model_dump()
        )
    return results
