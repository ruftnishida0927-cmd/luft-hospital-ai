import os
import zipfile
import pandas as pd
from datetime import datetime
from src.settings import OUTPUT_DIR


def _ensure_output_dir():
    os.makedirs(OUTPUT_DIR, exist_ok=True)


def export_to_excel(result: dict) -> str:
    _ensure_output_dir()
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(OUTPUT_DIR, f"hospital_analysis_{timestamp}.xlsx")
    with pd.ExcelWriter(path, engine="openpyxl") as writer:
        pd.DataFrame(result.get("summary_table", [])).to_excel(writer, sheet_name="病院サマリー", index=False)
        pd.DataFrame(result.get("hospital_profile", [])).to_excel(writer, sheet_name="基本情報", index=False)
        pd.DataFrame(result.get("facility_standards", [])).to_excel(writer, sheet_name="施設基準候補", index=False)
        pd.DataFrame(result.get("hiring_contacts", [])).to_excel(writer, sheet_name="採用窓口候補", index=False)
        pd.DataFrame(result.get("recruitment_signals", [])).to_excel(writer, sheet_name="採用関連", index=False)
        pd.DataFrame(result.get("phase_signals", [])).to_excel(writer, sheet_name="営業示唆", index=False)
        pd.DataFrame(result.get("policy_updates", [])).to_excel(writer, sheet_name="制度差分", index=False)
    return path


def export_to_csv_bundle(result: dict) -> str:
    _ensure_output_dir()
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    base_dir = os.path.join(OUTPUT_DIR, f"csv_bundle_{timestamp}")
    os.makedirs(base_dir, exist_ok=True)
    files = {
        "summary_table.csv": result.get("summary_table", []),
        "hospital_profile.csv": result.get("hospital_profile", []),
        "facility_standards.csv": result.get("facility_standards", []),
        "hiring_contacts.csv": result.get("hiring_contacts", []),
        "recruitment_signals.csv": result.get("recruitment_signals", []),
        "phase_signals.csv": result.get("phase_signals", []),
        "policy_updates.csv": result.get("policy_updates", []),
    }
    for filename, rows in files.items():
        pd.DataFrame(rows).to_csv(os.path.join(base_dir, filename), index=False, encoding="utf-8-sig")
    zip_path = os.path.join(OUTPUT_DIR, f"csv_bundle_{timestamp}.zip")
    with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
        for filename in files.keys():
            zf.write(os.path.join(base_dir, filename), arcname=filename)
    return zip_path
