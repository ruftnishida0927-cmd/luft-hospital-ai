import glob
import json
import os
from src.settings import KNOWLEDGE_DIR


def load_latest_policy_rules() -> list:
    if not os.path.exists(KNOWLEDGE_DIR):
        return []
    files = sorted(glob.glob(os.path.join(KNOWLEDGE_DIR, "policy_updates_*.json")))
    if not files:
        return []
    latest_file = files[-1]
    with open(latest_file, "r", encoding="utf-8") as f:
        return json.load(f)
