from __future__ import annotations

from src.models import RecruitmentSignal
from src.search_utils import search_web

JOB_TERMS = ["看護補助", "医療事務", "医師事務作業補助", "看護助手", "クラーク"]


def collect_recruitment_signals(hospital_name: str):
    rows = []
    seen = set()
    for term in JOB_TERMS:
        for result in search_web(f'{hospital_name} {term} 採用 求人', max_results=1):
            key = (term, result["url"])
            if key in seen:
                continue
            seen.add(key)
            rows.append(
                RecruitmentSignal(
                    hospital_name=hospital_name,
                    job_type=term,
                    employment_type=None,
                    channel_name="web_search",
                    job_url=result["url"],
                    comment=result["snippet"],
                ).model_dump()
            )
    if not rows:
        rows.append(
            RecruitmentSignal(
                hospital_name=hospital_name,
                job_type="要調査",
                channel_name="system",
                comment="公開求人の明確なヒットを取得できませんでした。",
            ).model_dump()
        )
    return rows
