from src.collectors.hospital_profile_collector import collect_hospital_profile
from src.collectors.hiring_contact_collector import collect_hiring_contacts
from src.collectors.facility_standard_collector import collect_facility_standards
from src.collectors.recruitment_collector import collect_recruitment_signals
from src.collectors.reimbursement_signal_collector import collect_reimbursement_revision_signals
from src.analyzers.phase_estimator import estimate_phase
from src.analyzers.sales_strategy import build_summary_markdown
from src.rule_engine import load_latest_policy_rules


class HospitalAnalysisOrchestrator:
    def run(self, hospital_name: str, prefecture: str = ""):
        profile = collect_hospital_profile(hospital_name, prefecture)
        contacts = collect_hiring_contacts(hospital_name)
        facilities = collect_facility_standards(hospital_name)
        recruitments = collect_recruitment_signals(hospital_name)
        reimbursement_signals = collect_reimbursement_revision_signals(hospital_name)
        phases = estimate_phase(hospital_name, facilities, recruitments, reimbursement_signals)
        policy_updates = load_latest_policy_rules()
        summary = build_summary_markdown(hospital_name, profile, contacts, facilities, recruitments, phases)
        summary_table = [{
            "hospital_name": hospital_name,
            "website_url": (profile[0].get("website_url") if profile else None),
            "predicted_phase": (phases[0].get("predicted_phase") if phases else None),
            "recommended_roles": (phases[0].get("recommended_roles") if phases else None),
            "sales_angle": (phases[0].get("sales_angle") if phases else None),
            "priority_score": (phases[0].get("priority_score") if phases else None),
            "contact_title": (contacts[0].get("title") if contacts else None),
            "contact_name": (contacts[0].get("person_name") if contacts else None),
            "contact_value": (contacts[0].get("contact_value") if contacts else None),
        }]
        return {
            "summary_markdown": summary,
            "hospital_profile": profile,
            "hiring_contacts": contacts,
            "facility_standards": facilities,
            "recruitment_signals": recruitments,
            "phase_signals": phases,
            "policy_updates": policy_updates,
            "summary_table": summary_table,
        }
